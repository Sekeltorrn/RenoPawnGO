<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ffffff"
    android:padding="24dp"
    tools:context="com.example.mobileapppawnshop.backend.OtpVerificationActivity">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:padding="4dp"
        android:src="@android:drawable/ic_menu_revert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#64748b" />

    <ImageView
        android:id="@+id/ivSecurityIcon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="32dp"
        android:src="@android:drawable/ic_lock_idle_lock"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:tint="#2563eb" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="sans-serif-black"
        android:text="VERIFY YOUR EMAIL"
        android:textColor="#1e3a8a"
        android:textSize="22sp"
        android:letterSpacing="0.05"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivSecurityIcon" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="We've sent a 6-digit secure code to your email. Enter it below to activate your account."
        android:textColor="#64748b"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <LinearLayout
        android:id="@+id/llOtpContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <EditText
            android:id="@+id/otp1"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/input_outline_blue"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="#1e3a8a"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/otp2"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/input_outline_blue"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="#1e3a8a"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/otp3"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/input_outline_blue"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="#1e3a8a"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/otp4"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/input_outline_blue"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="#1e3a8a"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/otp5"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/input_outline_blue"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="#1e3a8a"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/otp6"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:background="@drawable/input_outline_blue"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="#1e3a8a"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvErrorMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Invalid code. Please try again."
        android:textColor="#ef4444"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llOtpContainer" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnVerify"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/button_solid_blue"
        android:letterSpacing="0.1"
        android:text="VERIFY SECURE CODE"
        android:textColor="#ffffff"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvErrorMessage" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnVerify">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Didn't receive a code? "
            android:textColor="#64748b"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvResendCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RESEND"
            android:textColor="#2563eb"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
